{{define "dashboard"}}
<h1>Dashboard</h1>
<div id="container-l1" class="chart-container"></div>
<div id="container-l2" class="chart-container"></div>
<div id="container" style="width:100%; height:400px;"></div>
<script>
document.addEventListener('DOMContentLoaded', function () {

var gaugeOptions = {
    chart: {
        type: 'solidgauge'
    },

    title: null,

    pane: {
        center: ['50%', '85%'],
        size: '140%',
        startAngle: -90,
        endAngle: 90,
        background: {
            backgroundColor:
                Highcharts.defaultOptions.legend.backgroundColor || '#EEE',
            innerRadius: '60%',
            outerRadius: '100%',
            shape: 'arc'
        }
    },

    exporting: {
        enabled: false
    },

    tooltip: {
        enabled: false
    },

    // the value axis
    yAxis: {
        stops: [
            [0.1, '#55BF3B'], // green
            [0.5, '#DDDF0D'], // yellow
            [0.9, '#DF5353'] // red
        ],
        lineWidth: 0,
        tickWidth: 0,
        minorTickInterval: null,
        tickAmount: 2,
        title: {
            y: -70
        },
        labels: {
            y: 16
        }
    },

    plotOptions: {
        solidgauge: {
            dataLabels: {
                y: 5,
                borderWidth: 0,
                useHTML: true
            }
        }
    }
};

// The L1 gauge
var chartL1 = Highcharts.chart('container-l1', Highcharts.merge(gaugeOptions, {
    yAxis: {
        min: -25,
        max: 25,
        title: {
            text: 'Current'
        }
    },

    credits: {
        enabled: false
    },

    series: [{
        name: 'Current',
        data: [10],
        dataLabels: {
            format:
                '<div style="text-align:center">' +
                '<span style="font-size:25px">{y}</span><br/>' +
                '<span style="font-size:12px;opacity:0.4">A</span>' +
                '</div>'
        },
        tooltip: {
            valueSuffix: ' A'
        }
    }]

}));

var chartL2 = Highcharts.chart('container-l2', Highcharts.merge(gaugeOptions, {
    yAxis: {
        min: 0,
        max: 200,
        title: {
            text: 'Speed'
        }
    },

    credits: {
        enabled: false
    },

    series: [{
        name: 'Speed',
        data: [10],
        dataLabels: {
            format:
                '<div style="text-align:center">' +
                '<span style="font-size:25px">{y}</span><br/>' +
                '<span style="font-size:12px;opacity:0.4">km/h</span>' +
                '</div>'
        },
        tooltip: {
            valueSuffix: ' km/h'
        }
    }]

}));


// Bring life to the dials
setInterval(function () {
    // Speed
    var point,
        newVal,
        inc;

    if (chartL1) {
        point = chartL1.series[0].points[0];
        inc = Math.round((Math.random() - 0.5) * 25);
        newVal = point.y + inc;

        if (newVal < -25 || newVal > 25) {
            newVal = point.y - inc;
        }

        point.update(newVal);
    }

}, 2000);

});
</script>
{{end}}